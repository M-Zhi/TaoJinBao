<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1421">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- 统计卡片 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="#1E2A3A" android:padding="12dp" android:orientation="vertical">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="预测准确率分析（近90天）"
                android:textColor="#F0B429" android:textSize="13sp" android:textStyle="bold"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginTop="12dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="预测次数" android:textColor="#AAAAAA" android:textSize="11sp"/>
                    <TextView android:id="@+id/tv_total_count"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="#FFFFFF"
                        android:textSize="22sp" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="方向准确率" android:textColor="#AAAAAA" android:textSize="11sp"/>
                    <TextView android:id="@+id/tv_accuracy_rate"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--%" android:textColor="#4CAF50"
                        android:textSize="22sp" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="平均误差" android:textColor="#AAAAAA" android:textSize="11sp"/>
                    <TextView android:id="@+id/tv_avg_error"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--%"  android:textColor="#F0B429"
                        android:textSize="22sp" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="最大误差" android:textColor="#AAAAAA" android:textSize="11sp"/>
                    <TextView android:id="@+id/tv_max_error"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--%"  android:textColor="#FF6B6B"
                        android:textSize="22sp" android:textStyle="bold"/>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

        <!-- 预测vs实际 折线图 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="#1E2A3A" android:padding="12dp" android:orientation="vertical"
            android:layout_marginTop="8dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="预测价格 vs 实际价格"
                android:textColor="#F0B429" android:textSize="13sp" android:textStyle="bold"/>

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/deviation_chart"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- 预测偏差散点图 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="#1E2A3A" android:padding="12dp" android:orientation="vertical"
            android:layout_marginTop="8dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="预测偏差分布（预测-实际，¥）"
                android:textColor="#F0B429" android:textSize="13sp" android:textStyle="bold"/>

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/deviation_bar_chart"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- 说明（可点击弹出算法详情）-->
        <TextView
            android:id="@+id/tv_deviation_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="预测算法：Holt 双指数平滑 ⓘ"
            android:textColor="#4DABF7"
            android:textSize="11sp"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"/>

    </LinearLayout>
</ScrollView>
